  "paths": {
    "/sts/exchange": {
      "get": {
        "operationId": "SecurityTokenService_Exchange2",
        "parameters": [
          {
            "in": "query",
            "name": "aud",
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          {
            "description": "Deprecated: use scopes instead",
            "in": "query",
            "name": "scope",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "identity",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "List of capabilities to request for the token.",
            "in": "query",
            "name": "cap",
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          {
            "description": "Empty or the UIDP of the custom identity provider.",
            "in": "query",
            "name": "identityProvider",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "One or more group scopes to restrict the returned token to.\nIf scope and scopes are both provided, the union of their values is\nconsidered, after deduplication.\n\nThe returned token will include role bindings for the requested scopes,\nif any exist, that are either granted directly at that scope or inherited from\nits ancestors. That is, a role binding granted at a \"lower\" scope in the ancestry\napplies to all descendants of that scope.\n\nFor example, given a role binding on group `foo` with id `foo/rb-id-1`\nand a role binding on group `foo/bar` with id `foo/bar/rb-id-2`:\n - given scopes = [foo, foo/bar] =\u003e {foo: [foo/rb-id-1], foo/bar: [foo/bar/rb-id-2]}\n - given scopes = [foo/bar] =\u003e {foo/bar: [foo/rb-id-1, foo/bar/rb-id-2]}",
            "in": "query",
            "name": "scopes",
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/chainguard.platform.oidc.RawToken"
                }
              }
            },
            "description": "A successful response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/google.rpc.Status"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "summary": "Exchange2",
        "tags": [
          "SecurityTokenService"
        ]
      },
